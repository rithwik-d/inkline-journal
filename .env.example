PORT=3000
SESSION_SECRET=replace-with-a-strong-random-value
APP_BASE_URL=http://localhost:3000
EMAIL_VERIFY_TTL_HOURS=24

# Optional SMTP settings for signup verification emails.
# If these are omitted, verification links are printed to server console for local development.
