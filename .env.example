PORT=3000
SESSION_SECRET=replace-with-a-strong-random-value
APP_BASE_URL=http://localhost:3000
EMAIL_VERIFY_TTL_HOURS=24

# Postgres connection (required)
# Local example:
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/inkline_journal
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/inkline_journal
# Set to true for hosted Postgres providers that require SSL (Neon/Supabase/Render/etc.).
PGSSL=false

# SMTP settings for signup verification emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=app-specific-password
SMTP_FROM=Inkline Journal <no-reply@example.com>
