PORT=3000
SESSION_SECRET=replace-with-a-strong-random-value

# Postgres connection (required)
# Local example:
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/inkline_journal
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/inkline_journal
# Set to true for hosted Postgres providers that require SSL (Neon/Supabase/Render/etc.).
PGSSL=false
