PORT=3000
SESSION_SECRET=replace-with-a-strong-random-value
OTP_TTL_MINUTES=10

# Optional SMTP settings for OTP email delivery.
# If these are omitted, OTP codes are printed to server console for local development.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
SMTP_PASS=app-specific-password
SMTP_FROM=Inkline Journal <no-reply@example.com>
