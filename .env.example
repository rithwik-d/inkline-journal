# Copy this file to `.env` for local development.

PORT=3001
APP_BASE_URL=http://localhost:3001
CLIENT_BASE_URL=http://localhost:5173

# If your database password contains characters like # or @, URL-encode them.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/inkline_journal_local
PGSSL=false

SESSION_SECRET=replace-with-a-long-random-secret
SESSION_COOKIE_SECURE=false

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

SUPPORT_EMAIL=support@inklinejournal.com
SMTP_FROM=support@inklinejournal.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=support@inklinejournal.com
SMTP_PASS=your-16-char-app-password
SMTP_SECURE=false
EMAIL_VERIFY_TTL_HOURS=24
