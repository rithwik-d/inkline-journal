<%- include('partials/head', { title, activePage }) %>

<section class="auth-shell">
  <h1>Verify OTP</h1>
  <p>Enter the 6-digit code sent to <strong><%= pendingEmail %></strong>.</p>

  <% if (errors.length > 0) { %>
    <div class="alert">
      <ul>
        <% errors.forEach((error) => { %>
          <li><%= error %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <form class="post-form" action="/verify-otp" method="post">
    <label for="otp">One-Time Password</label>
    <input id="otp" name="otp" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" required />

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Verify & Login</button>
      <a class="btn btn-soft" href="/login">Start over</a>
    </div>
  </form>
</section>

<%- include('partials/footer') %>
