<%- include('partials/head', { title: 'Edit Post', activePage: 'home' }) %>

<section class="form-shell">
  <h1>Edit Post</h1>
  <p>Last updated <%= formatDate(post.updatedAt) %></p>

  <% if (errors.length > 0) { %>
    <div class="alert">
      <h2>Fix the following issues:</h2>
      <ul>
        <% errors.forEach((error) => { %>
          <li><%= error %></li>
        <% }); %>
      </ul>
    </div>
  <% } %>

  <form class="post-form" action="/posts/<%= post.id %>?_method=PATCH" method="post">
    <label for="title">Title</label>
    <input id="title" name="title" maxlength="120" value="<%= formData.title %>" required />

    <label for="author">Author (optional)</label>
    <input id="author" name="author" maxlength="80" value="<%= formData.author %>" />

    <label for="content">Content</label>
    <textarea id="content" name="content" rows="12" required><%= formData.content %></textarea>

    <div class="form-actions">
      <button class="btn btn-primary" type="submit">Save Changes</button>
      <a class="btn btn-soft" href="/posts/<%= post.id %>">Cancel</a>
    </div>
  </form>
</section>

<%- include('partials/footer') %>
