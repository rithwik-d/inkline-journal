<%- include('partials/head', { title: 'Home', activePage }) %>

<section class="hero-card">
  <p class="eyebrow">Public Writing Space</p>
  <h1>Read stories from the community and publish your own voice.</h1>
  <p class="hero-quote">"<%= quote %>"</p>

  <div class="hero-actions">
    <% if (currentUser) { %>
      <a class="btn btn-primary" href="/posts/new">Write a Story</a>
      <a class="btn btn-soft" href="/dashboard">Open Dashboard</a>
    <% } else { %>
      <a class="btn btn-primary" href="/signup">Create Account</a>
      <a class="btn btn-soft" href="/login">Login</a>
    <% } %>
  </div>
</section>

<section class="feed-section">
  <div class="section-head">
    <h2>Latest Public Posts</h2>
    <p>Every published post appears here for everyone to read.</p>
  </div>

  <% if (posts.length === 0) { %>
    <article class="empty-state">
      <h3>No public posts yet</h3>
      <p>Be the first to publish a story in Inkline Journal.</p>
    </article>
  <% } else { %>
    <div class="post-grid">
      <% posts.forEach((post) => { %>
        <article class="post-card">
          <p class="meta">
            By <strong><%= post.display_name || post.email.split('@')[0] %></strong> -
            <%= formatDate(post.updated_at) %>
          </p>
          <h3><a href="/posts/<%= post.id %>"><%= post.title %></a></h3>
          <p class="content-preview"><%= excerpt(post.content, 210) %></p>
          <a class="text-link" href="/posts/<%= post.id %>">Read full story</a>
        </article>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include('partials/footer') %>
