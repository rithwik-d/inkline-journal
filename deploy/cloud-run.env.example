NODE_ENV=production
APP_BASE_URL=https://YOUR_CLOUD_RUN_URL_OR_CUSTOM_DOMAIN
CLIENT_BASE_URL=https://YOUR_CLOUD_RUN_URL_OR_CUSTOM_DOMAIN
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_COOKIE_SECURE=true
DATABASE_URL=postgresql://USERNAME:PASSWORD@YOUR-NEON-HOST/DATABASE?sslmode=require&channel_binding=require
PGSSL=true
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_CALLBACK_URL=https://YOUR_CLOUD_RUN_URL_OR_CUSTOM_DOMAIN/api/auth/google/callback
SUPPORT_EMAIL=support@inklinejournal.com
SMTP_FROM=support@inklinejournal.com
SMTP_HOST=your-smtp-host
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_SECURE=false
EMAIL_VERIFY_TTL_HOURS=24
